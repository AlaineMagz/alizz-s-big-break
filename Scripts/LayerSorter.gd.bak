func _process(_delta):
	
	clearArrs()
	
	getObjectNoFloorArr()
	getYArr()
	

func clearArrs():
	
	objectNoFloorArr.clear()
	yArr.clear()
	

func getObjectNoFloorArr():
	
	objectNoFloorArr.append(player)
	
	for wl in level.wallManager.wallArr:
		objectNoFloorArr.append(wl)
	

